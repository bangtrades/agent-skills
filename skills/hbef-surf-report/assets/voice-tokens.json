  "format_targets": {
    "article": {
      "min_words": 80,
      "max_words": 150,
      "headline_words_min": 4,
      "headline_words_max": 8,
      "first_sentence_words_min": 20,
      "first_sentence_words_max": 35,
      "bold_phrases_target": [2, 4],
      "hyperlinks_max": 2,
      "emojis_max": 1,
      "hashtags_in_body": 0,
      "image_suggestions_required": true
    },
    "surf_report_extra": {
      "min_words": 100,
      "max_words": 250,
      "single_topic_only": true
    }
  },
  "emoji_palette_surf_report": {
    "approved": ["📚", "❤️", "⛳", "☀️", "🎉"],
    "use_cap_per_article": 1,
    "use_strict": true,
    "comment": "Surf Report is text-forward. Emoji is signaling, not decoration. Use significantly less than the Facebook palette."
  },
  "bold_emphasis_targets": [
    "dates and deadlines",
    "dollar amounts and percentages",
    "discount codes",
    "school names on first mention",
    "time windows",
    "key reader actions",
    "the primary number/goal in the article"
  ],
  "submission_workflow": {
    "submit_to": "communications@hvpto.com",
